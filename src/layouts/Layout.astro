---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = '鬼と学ぼう！算数アドベンチャー', description = 'おにの学校で楽しく学べる算数アプリ' } = Astro.props;
const siteUrl = 'https://addition.ikk-dev.jp';
const ogTitle = title === '鬼と学ぼう！算数アドベンチャー' ? title : `${title} | 鬼と学ぼう！算数アドベンチャー`;
const ogImage = `${siteUrl}/ogp.png`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="鬼と学ぼう！算数アドベンチャー" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Icons & PWA -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#03120b" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="算数アドベンチャー" />
    <title>{ogTitle}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Persistent BGM element (survives page transitions) -->
    <audio id="bgm-audio" data-astro-transition-persist="bgm" preload="auto"></audio>

    <!-- Top bar / HUD -->
    <header
      class="sticky top-0 z-40 w-full border-b border-[#1f7a4d]/30 bg-[#051a10]/80 backdrop-blur-md"
      x-data="{}"
    >
      <div class="mx-auto flex w-full max-w-3xl items-center justify-between px-4 py-2">
        <a href="/" class="flex items-center gap-2 group">
          <span class="text-lg">👹</span>
          <span class="text-sm font-black tracking-tight text-[#3ddc84]">
            鬼と学ぼう！算数アドベンチャー
          </span>
        </a>
        <div class="flex items-center gap-1">
          <a href="/ranking" class="btn-ghost px-3 py-1.5 text-xs font-bold">ランキング</a>
          <button
            type="button"
            title="サウンド切替"
            class="btn-ghost px-3 py-1.5 text-xs font-bold"
            x-data="{ muted: false }"
            @click="muted = $store.game.audio ? $store.game.audio.toggleMute() : muted"
            x-text="muted ? '🔇' : '🔊'"
          >🔊</button>
        </div>
      </div>
    </header>

    <main class="flex flex-1 flex-col items-center justify-center px-6 sm:px-4 py-4">
      <slot />
    </main>

    <footer class="w-full py-3 text-center text-[10px] text-[#9db8a8]/50">
      © 鬼と学ぼう！算数アドベンチャー — 計算力でクリアせよ
    </footer>

    <script>
      // Expose Astro's SPA navigation so client transitions keep the in-memory
      // Alpine store alive (full reloads would reset the game state).
      import { navigate } from 'astro:transitions/client';
      (window as any).astroNavigate = navigate;
    </script>
  </body>
</html>
