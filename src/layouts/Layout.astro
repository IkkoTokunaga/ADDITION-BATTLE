---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = '鬼退治足し算バトル', description = '足し算で鬼を退治するバトル学習ゲーム' } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | 鬼退治足し算バトル</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Persistent BGM element (survives page transitions) -->
    <audio id="bgm-audio" data-astro-transition-persist="bgm" preload="auto"></audio>

    <!-- Top bar / HUD -->
    <header
      class="sticky top-0 z-40 w-full border-b border-[#9b5de5]/20 bg-[#0b0914]/70 backdrop-blur-md"
      x-data="{}"
    >
      <div class="mx-auto flex w-full max-w-3xl items-center justify-between px-4 py-2">
        <a href="/" class="flex items-center gap-2 group">
          <span class="text-lg">👹</span>
          <span class="text-sm font-black tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-[#9b5de5] to-[#f15bb5]">
            鬼退治足し算バトル
          </span>
        </a>
        <div class="flex items-center gap-1">
          <a href="/ranking" class="btn-ghost px-3 py-1.5 text-xs font-bold">ランキング</a>
          <button
            type="button"
            title="サウンド切替"
            class="btn-ghost px-3 py-1.5 text-xs font-bold"
            x-data="{ muted: false }"
            @click="muted = $store.game.audio ? $store.game.audio.toggleMute() : muted"
            x-text="muted ? '🔇' : '🔊'"
          >🔊</button>
        </div>
      </div>
    </header>

    <main class="flex flex-1 flex-col items-center justify-center px-4 py-4">
      <slot />
    </main>

    <footer class="w-full py-3 text-center text-[10px] text-[#b5a9df]/40">
      © 鬼退治足し算バトル — 計算力でクリアせよ
    </footer>

    <script>
      // Expose Astro's SPA navigation so client transitions keep the in-memory
      // Alpine store alive (full reloads would reset the game state).
      import { navigate } from 'astro:transitions/client';
      (window as any).astroNavigate = navigate;
    </script>
  </body>
</html>
