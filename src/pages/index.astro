---
import Layout from '../layouts/Layout.astro';
---

<Layout title="スタート" description="鬼と学ぼう！算数アドベンチャー — おにの学校で楽しく算数を学ぼう！">
  <div
    x-data="{
      init() {
        this.$store.game.goBackToTitle();
      },
      async start() {
        await this.$store.game.startNewGame();
        if (typeof window !== 'undefined' && window.astroNavigate) {
          window.astroNavigate('/game');
        } else {
          window.location.href = '/game';
        }
      }
    }"
    class="w-full max-w-5xl mx-auto flex flex-col items-center justify-center gap-5 py-2"
  >
    <!-- Hero banner (responsive: mobile / pc) with overlaid start button -->
    <div class="relative w-full hero-banner">
      <h1 class="sr-only">鬼と学ぼう！算数アドベンチャー 〜 おにの学校で楽しく学べる算数アプリ 〜</h1>
      <picture>
        <source media="(min-width: 768px)" srcset="/images/top-pc.png" />
        <img
          src="/images/top-mobile.png"
          alt="鬼と学ぼう！算数アドベンチャー — おにの学校で楽しく学べる算数アプリ"
          class="block w-full h-auto"
          fetchpriority="high"
        />
      </picture>

      <!-- Overlaid CTA -->
      <div class="absolute inset-x-0 bottom-0 flex justify-center pb-[5%]">
        <button
          type="button"
          @click="start()"
          class="btn-primary btn-shine font-black px-10 sm:px-14 py-3 sm:py-4 text-lg sm:text-2xl tracking-wider"
        >
          修行を開始する！
        </button>
      </div>
    </div>

    <!-- Secondary actions -->
    <a href="/ranking" class="btn-ghost text-center font-bold px-6 py-2.5 text-sm">
      🏆 ランキングを見る
    </a>

    <!-- Rules -->
    <div class="w-full text-center text-xs text-[#9db8a8] leading-relaxed max-w-md">
      <p class="font-bold text-[#f5c518] mb-1">【ゲームのルール】</p>
      <p>
        足し算の答えをテンキーかキーボードで入力しよう。正解すると鬼にダメージ（速く答えるほど高得点！）、間違えると女教師のライフが1つ減少します。ライフ3個を守りながら鬼を倒そう！
      </p>
    </div>
  </div>
</Layout>

<script>
  import Alpine from 'alpinejs';
  import { gameStore } from '../scripts/game';

  if (!Alpine.store('game')) {
    Alpine.store('game', gameStore());
  }
</script>
