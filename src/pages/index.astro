---
import Layout from '../layouts/Layout.astro';
---

<Layout title="スタート" description="鬼退治足し算バトルで楽しく算数を学ぼう！名前を入力してバトル開始！">
  <div
    x-data="{
      inputName: '',
      init() {
        const saved = this.$store.game.username || '';
        this.inputName = saved === 'ゲスト' ? '' : saved;
        this.$store.game.goBackToTitle();
      },
      async start() {
        let name = this.inputName.trim() || 'ゲスト';
        await this.$store.game.startNewGame(name);
        if (typeof window !== 'undefined' && window.astroNavigate) {
          window.astroNavigate('/game');
        } else {
          window.location.href = '/game';
        }
      }
    }"
    class="w-full max-w-lg mx-auto flex flex-col items-center justify-center gap-6 py-4"
  >
    <!-- Title -->
    <div class="text-center flex flex-col items-center gap-3">
      <div class="relative w-28 h-40 flex items-center justify-center bg-[#130f24]/40 rounded-2xl overflow-hidden float-idle border border-[#9b5de5]/20">
        <img src="/images/女教師.png" alt="数学の女教師" class="w-full h-full object-contain" />
      </div>
      <h1 class="text-3xl md:text-4xl font-black tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-[#9b5de5] via-[#f15bb5] to-[#fee440] glow-text-purple">
        鬼退治足し算バトル
      </h1>
      <p class="text-xs md:text-sm text-[#b5a9df]">〜 計算力を鍛えて強力な鬼を撃破せよ！ 〜</p>
    </div>

    <!-- Start panel -->
    <div class="w-full glass-panel p-6 md:p-8 flex flex-col gap-5">
      <div class="flex flex-col gap-2">
        <label for="username-input" class="text-xs font-bold uppercase tracking-wider text-[#b5a9df]">
          ニックネーム（未入力の場合は「ゲスト」）
        </label>
        <input
          type="text"
          id="username-input"
          x-model="inputName"
          @keydown.enter="start()"
          placeholder="ゲスト"
          maxlength="20"
          class="w-full px-4 py-3 bg-[#0b0914]/80 border border-[#9b5de5]/30 rounded-12 text-[#f3f0ff] font-bold text-center text-lg focus:outline-none focus:border-[#f15bb5] focus:ring-1 focus:ring-[#f15bb5] transition-all placeholder:text-[#b5a9df]/30"
        />
      </div>
      <button
        type="button"
        @click="start()"
        class="w-full btn-primary font-black py-4 text-xl tracking-wider"
      >
        修行を開始する！
      </button>
    </div>

    <!-- Rules -->
    <div class="w-full text-center text-xs text-[#b5a9df]/70 leading-relaxed max-w-sm">
      <p class="font-bold text-[#fee440] mb-1">【ゲームのルール】</p>
      <p>
        足し算の答えをテンキーかキーボードで入力しよう。正解すると鬼にダメージ（速く答えるほど高得点！）、間違えると女教師のライフが1つ減少します。ライフ3個を守りながら鬼を倒そう！
      </p>
    </div>
  </div>
</Layout>

<script>
  import Alpine from 'alpinejs';
  import { gameStore } from '../scripts/game';

  if (!Alpine.store('game')) {
    Alpine.store('game', gameStore());
  }
</script>
