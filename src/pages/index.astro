---
import Layout from '../layouts/Layout.astro';
---

<Layout title="スタート画面" description="鬼退治足し算バトルゲームで楽しく算数を学ぼう！名前を入力してバトル開始！">
  <div 
    x-data="{ 
      inputName: '',
      init() {
        // Pre-fill username if exists (ignore 'ゲスト')
        const savedName = this.$store.game.username || '';
        this.inputName = savedName === 'ゲスト' ? '' : savedName;
        this.$store.game.goBackToTitle(); // Reset state and set BGM to HOME-BGM
      },
      async start() {
        let name = this.inputName.trim();
        if (!name) {
          name = 'ゲスト';
        }
        // Save and start the game in store
        await this.$store.game.startNewGame(name);
        
        // Client-side navigate to game page using Astro's transition router
        if (typeof window !== 'undefined' && window.astroNavigate) {
          window.astroNavigate('/game');
        } else {
          window.location.href = '/game';
        }
      }
    }"
    class="w-full max-w-lg mx-auto flex flex-col items-center justify-center gap-4 md:gap-8 py-4 md:py-8"
  >
    <!-- Game Logo/Title -->
    <div class="text-center flex flex-col items-center gap-2">
      <div class="relative w-24 h-36 mb-2 flex items-center justify-center bg-[#130f24]/30 rounded-2xl overflow-hidden">
        <!-- Display Math Teacher Character Preview -->
        <img 
          src="/images/女教師.png" 
          alt="数学の女教師" 
          class="w-full h-full object-contain hover:scale-105 transition-transform duration-500"
        />
      </div>
      <h1 class="text-2xl md:text-4xl font-black tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-[#9b5de5] via-[#f15bb5] to-[#fee440] glow-text-purple">
        鬼退治足し算バトル
      </h1>
      <p class="text-xs md:text-sm text-[#b5a9df] mt-1">〜 計算力を鍛えて強力な鬼を撃破せよ！ 〜</p>
    </div>

    <!-- Start Panel -->
    <div class="w-full glass-panel p-4 md:p-8 flex flex-col gap-4 md:gap-6">
      <div class="flex flex-col gap-2">
        <label for="username-input" class="text-xs font-bold uppercase tracking-wider text-[#b5a9df]">ニックネーム（未入力の場合は「ゲスト」）</label>
        <input 
          type="text" 
          id="username-input" 
          x-model="inputName" 
          @keydown.enter="start()"
          placeholder="ゲスト (未入力でもスタートできます)" 
          maxlength="20"
          class="w-full px-4 py-3 bg-[#0b0914]/80 border border-[#9b5de5]/30 rounded-12 text-[#f3f0ff] font-bold text-center text-lg focus:outline-none focus:border-[#f15bb5] focus:ring-1 focus:ring-[#f15bb5] transition-all placeholder:text-[#b5a9df]/30"
        />
      </div>

      <button 
        type="button" 
        id="start-game-btn" 
        @click="start()" 
        class="w-full btn-primary font-black py-4 text-xl tracking-wider"
      >
        修行を開始する！
      </button>
    </div>

    <!-- Rules / Description -->
    <div class="w-full text-center text-xs text-[#b5a9df]/70 leading-relaxed max-w-sm">
      <p class="font-bold text-[#fee440] mb-1">【ゲームのルール】</p>
      <p>制限時間10秒以内に足し算の答えをテンキーかキーボードで入力してください。正解すると鬼にダメージ、間違えると女教師のライフが減少します！</p>
    </div>
  </div>
</Layout>

<script>
  import Alpine from 'alpinejs';
  import { gameStore } from '../scripts/game';
  
  // Register Alpine store for state preservation across transitions
  if (!Alpine.store('game')) {
    Alpine.store('game', gameStore());
  }
</script>
