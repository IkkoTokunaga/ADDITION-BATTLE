---
import Layout from '../layouts/Layout.astro';
import { query } from '../utils/db';

export const prerender = false;

let scores: any[] = [];
try {
  const result = await query(
    'SELECT username, score, stage, created_at FROM scores ORDER BY score DESC, stage DESC, created_at ASC LIMIT 10'
  );
  scores = result.rows;
} catch (e) {
  scores = [];
}

const medals = ['🥇', '🥈', '🥉'];
---

<Layout title="ランキング" description="鬼と学ぼう！算数アドベンチャーのハイスコアランキング">
  <div
    x-data="{ init() { if (this.$store.game.audio) this.$store.game.audio.playBGM('ranking'); } }"
    class="w-full max-w-md mx-auto flex flex-col gap-4 py-2"
  >
    <div class="text-center flex flex-col gap-1">
      <h1 class="text-3xl font-black text-[#f5c518] glow-text-gold">
        ランキング
      </h1>
      <p class="text-xs text-[#9db8a8]">トップ10の計算マスターたち</p>
    </div>

    <div class="glass-panel p-3 flex flex-col gap-1">
      {
        scores.length === 0 ? (
          <p class="py-8 text-center text-sm text-[#9db8a8]/70">まだ記録がありません。<br />最初の挑戦者になろう！</p>
        ) : (
          scores.map((s, i) => (
            <div class={`flex items-center gap-3 rounded-12 px-3 py-2.5 ${i < 3 ? 'bg-[#1f7a4d]/18' : ''}`}>
              <div class="w-8 text-center text-lg font-black">
                {i < 3 ? medals[i] : <span class="text-[#9db8a8]">{i + 1}</span>}
              </div>
              <div class="flex-1 min-w-0">
                <div class="truncate font-bold text-[#eaf5ee]">{s.username}</div>
                <div class="text-[10px] text-[#9db8a8]">ステージ {s.stage} 到達</div>
              </div>
              <div class="text-right font-black text-[#3ddc84]">
                {Number(s.score).toLocaleString()}
              </div>
            </div>
          ))
        )
      }
    </div>

    <div class="flex flex-col gap-2">
      <a href="/" class="w-full btn-primary text-center font-black py-3 text-lg">バトルに挑戦する！</a>
    </div>
  </div>
</Layout>

<script>
  import Alpine from 'alpinejs';
  import { gameStore } from '../scripts/game';

  if (!Alpine.store('game')) {
    Alpine.store('game', gameStore());
  }
</script>
