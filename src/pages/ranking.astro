---
import Layout from '../layouts/Layout.astro';
import { query } from '../utils/db';

export const prerender = false;

let scores: any[] = [];
try {
  const result = await query(
    'SELECT username, score, stage, created_at FROM scores ORDER BY score DESC, stage DESC, created_at ASC LIMIT 10'
  );
  scores = result.rows;
} catch (e) {
  scores = [];
}

// When the player arrives straight from a result registration, `?r=<scoreId>`
// is present: show their rank with the surrounding ±3 records, highlighted.
const rParam = Astro.url.searchParams.get('r');
const targetId = rParam && /^\d+$/.test(rParam) ? Number(rParam) : null;
let myWindow: any[] = [];
let myRank: number | null = null;
if (targetId !== null) {
  try {
    const result = await query(
      `WITH ranked AS (
         SELECT id, username, score, stage, created_at,
                ROW_NUMBER() OVER (ORDER BY score DESC, stage DESC, created_at ASC) AS rn
         FROM scores
       )
       SELECT id, username, score, stage, created_at, rn FROM ranked
       WHERE rn BETWEEN
         (SELECT rn FROM ranked WHERE id = $1) - 3
         AND (SELECT rn FROM ranked WHERE id = $1) + 3
       ORDER BY rn`,
      [targetId]
    );
    myWindow = result.rows;
    const me = myWindow.find((s) => Number(s.id) === targetId);
    myRank = me ? Number(me.rn) : null;
  } catch (e) {
    myWindow = [];
    myRank = null;
  }
}

const medals = ['🥇', '🥈', '🥉'];

function formatDate(d: Date | string | null): string {
  if (!d) return '';
  return new Date(d).toLocaleString('ja-JP', {
    timeZone: 'Asia/Tokyo',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
  });
}
---

<Layout title="ランキング" description="鬼と学ぼう！算数アドベンチャーのハイスコアランキング">
  <div
    x-data="{ init() { if (this.$store.game.audio) this.$store.game.audio.playBGM('ranking'); } }"
    class="w-full max-w-md mx-auto flex flex-col gap-4 py-2"
  >
    <div class="text-center flex flex-col gap-1">
      <h1 class="text-3xl font-black text-[#f5c518] glow-text-gold">
        ランキング
      </h1>
    </div>

    {
      targetId !== null && myWindow.length > 0 && (
        <div class="flex flex-col gap-2">
          <div class="text-center flex flex-col gap-0.5">
            <p class="text-xs font-bold text-[#9db8a8]">今回のプレイ</p>
            {myRank !== null && (
              <p class="text-2xl font-black text-[#f5c518] glow-text-gold">{myRank}位</p>
            )}
          </div>
          <div class="glass-panel p-3 flex flex-col gap-1">
            {myWindow.map((s) => {
              const rn = Number(s.rn);
              const isMe = Number(s.id) === targetId;
              return (
                <div
                  class={`flex items-center gap-3 rounded-12 px-3 py-2.5 ${
                    isMe
                      ? 'bg-[#3ddc84]/20 ring-2 ring-[#3ddc84]'
                      : rn <= 3
                        ? 'bg-[#1f7a4d]/18'
                        : ''
                  }`}
                >
                  <div class="w-8 text-center text-lg font-black">
                    {rn <= 3 ? medals[rn - 1] : <span class="text-[#9db8a8]">{rn}</span>}
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class={`truncate font-bold ${isMe ? 'text-[#3ddc84]' : 'text-[#eaf5ee]'}`}>
                      {s.username}
                      {isMe && <span class="ml-1 text-[10px] font-black text-[#04140d] bg-[#3ddc84] rounded-full px-1.5 py-0.5">YOU</span>}
                    </div>
                    <div class="text-[11px] text-[#9db8a8]">ステージ {s.stage} 到達</div>
                  </div>
                  <div class="text-right shrink-0">
                    <div class="font-black text-[#3ddc84]">{Number(s.score).toLocaleString()}</div>
                    <div class="text-[10px] text-[#9db8a8]/70">{formatDate(s.created_at)}</div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )
    }

    <div class="flex flex-col gap-2">
      <a href="/" class="w-full btn-primary text-center font-black py-3 text-lg">スタート画面に戻る</a>
    </div>

    <div class="text-center">
      <p class="text-xs font-bold text-[#9db8a8]">TOP10ランキング</p>
    </div>

    <div class="glass-panel p-3 flex flex-col gap-1">
      {
        scores.length === 0 ? (
          <p class="py-8 text-center text-sm text-[#9db8a8]/70">まだ記録がありません。<br />最初の挑戦者になろう！</p>
        ) : (
          scores.map((s, i) => (
            <div class={`flex items-center gap-3 rounded-12 px-3 py-2.5 ${i < 3 ? 'bg-[#1f7a4d]/18' : ''}`}>
              <div class="w-8 text-center text-lg font-black">
                {i < 3 ? medals[i] : <span class="text-[#9db8a8]">{i + 1}</span>}
              </div>
              <div class="flex-1 min-w-0">
                <div class="truncate font-bold text-[#eaf5ee]">{s.username}</div>
                <div class="text-[11px] text-[#9db8a8]">ステージ {s.stage} 到達</div>
              </div>
              <div class="text-right shrink-0">
                <div class="font-black text-[#3ddc84]">{Number(s.score).toLocaleString()}</div>
                <div class="text-[10px] text-[#9db8a8]/70">{formatDate(s.created_at)}</div>
              </div>
            </div>
          ))
        )
      }
    </div>
  </div>
</Layout>

<script>
  import Alpine from 'alpinejs';
  import { gameStore } from '../scripts/game';

  if (!Alpine.store('game')) {
    Alpine.store('game', gameStore());
  }
</script>
