---
import Layout from '../layouts/Layout.astro';
---

<Layout title="バトル" description="鬼退治足し算バトル プレイ画面">
  <div
    x-data="{
      oniImages: [
        '/images/ステージ1赤鬼.png',
        '/images/ステージ2青鬼.png',
        '/images/ステージ3黄鬼.png',
        '/images/ステージ4緑鬼.png',
        '/images/ステージ5紫鬼.png',
        '/images/ステージ6強赤鬼.png',
        '/images/ステージ7強青鬼.png',
        '/images/ステージ8強黄鬼.png',
        '/images/ステージ9強緑鬼.png',
        '/images/ステージ10強紫鬼.png',
        '/images/ステージ11強黒鬼.png',
        '/images/ステージ12上級鬼.png'
      ],
      get g() { return this.$store.game; },
      init() {
        if (!this.g.started) {
          if (window.astroNavigate) window.astroNavigate('/'); else window.location.href = '/';
        }
      }
    }"
    class="relative w-full max-w-md landscape:max-w-3xl mx-auto flex flex-col gap-3"
  >
    <!-- ===== Battlefield (top) ===== -->
    <!-- Images are placed free-standing, NOT inside any framed panel. -->
    <div class="grid grid-cols-[1fr_auto_1fr] items-end gap-1 sm:gap-2">

      <!-- 女教師 block (top-left) -->
      <div class="flex flex-col items-center gap-1.5">
        <img
          src="/images/女教師.png"
          alt="女教師"
          class="h-28 sm:h-36 w-auto object-contain drop-shadow-[0_0_18px_rgba(0,245,212,0.45)]"
          :class="{ 'is-shaking': g.takingDamage }"
        />
        <div class="flex items-center gap-0.5 text-lg leading-none">
          <template x-for="i in 3" :key="i">
            <span
              :class="(g.brokenHeart === (i-1)) ? 'heart-breaking' : ''"
              x-text="(g.brokenHeart === (i-1)) ? '💔' : ((i-1) < g.lives ? '❤️' : '🤍')"
            ></span>
          </template>
        </div>
        <div class="w-full max-w-[150px] flex flex-col gap-0.5">
          <div class="flex items-center justify-between text-[9px] font-bold leading-none">
            <span
              class="tracking-wider transition-colors"
              :class="g.specialGauge >= 75 ? 'text-[#fee440] glow-text-cyan' : 'text-[#b5a9df]'"
            >必殺技</span>
            <span class="text-[#b5a9df]/70" x-text="Math.min(100, Math.floor(g.specialGauge)) + '%'"></span>
          </div>
          <div class="hp-track h-2 w-full" :class="g.specialGauge >= 75 ? 'special-track-hot' : ''">
            <div class="hp-fill-special" :style="`width:${Math.min(100, g.specialGauge)}%`"></div>
          </div>
        </div>
      </div>

      <!-- Score / Stage (center, between teacher and oni) -->
      <div class="flex flex-col items-center gap-0.5 pb-6 sm:pb-10">
        <span class="text-[9px] uppercase tracking-wider text-[#b5a9df]">Stage</span>
        <span class="text-sm font-black text-[#fee440] glow-text-cyan leading-none">
          <span x-text="g.stage"></span><span class="text-[#b5a9df]/60 text-[10px]"> / 12</span>
        </span>
        <span class="text-base text-[#9b5de5] leading-none mt-0.5">⚔️</span>
        <span class="text-[9px] uppercase tracking-wider text-[#b5a9df] mt-0.5">Score</span>
        <span
          class="text-lg font-black text-transparent bg-clip-text bg-gradient-to-r from-[#00f5d4] to-[#00bbf9] leading-none"
          x-text="g.score.toLocaleString()"
        ></span>
      </div>

      <!-- 鬼 block (top-right). Oni is rendered slightly larger than the teacher. -->
      <div class="flex flex-col items-center gap-1.5">
        <div class="relative flex items-end justify-center">
          <img
            :src="oniImages[Math.min(Math.max(g.stage,1),12)-1]"
            alt="鬼"
            class="h-48 sm:h-56 w-auto object-contain drop-shadow-[0_0_24px_rgba(241,91,181,0.5)]"
            :class="{ 'is-shaking': g.shaking, 'is-exploding': g.explode, 'float-idle': !g.shaking && !g.explode }"
          />
          <template x-if="g.explode">
            <div class="shockwave"></div>
          </template>
          <template x-if="g.superAttacking">
            <div class="super-beam"></div>
          </template>
          <template x-for="f in g.floatingTexts" :key="f.id">
            <div
              class="floating-damage"
              :class="{ 'is-super': f.special }"
              x-text="(f.special ? '必殺! -' : '-') + f.value.toLocaleString()"
            ></div>
          </template>
        </div>
        <div class="w-full max-w-[160px] flex flex-col gap-0.5">
          <div class="flex items-center justify-between text-[9px] font-bold text-[#f15bb5] leading-none">
            <span>鬼 HP</span>
            <span><span x-text="Math.ceil(g.oniHp).toLocaleString()"></span> / <span x-text="g.oniMaxHp.toLocaleString()"></span></span>
          </div>
          <div class="hp-track h-3 w-full">
            <div class="hp-fill-oni" :style="`width:${g.oniHpPercent}%`"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== Question + Numpad (bottom) =====
         landscape: question left / numpad right ; portrait: question top / numpad below -->
    <div class="flex flex-col landscape:flex-row landscape:items-stretch gap-3">
      <!-- Question -->
      <div class="glass-panel px-4 py-4 flex flex-col items-center justify-center gap-3 landscape:flex-1">
        <div class="flex items-center justify-center gap-2 text-3xl md:text-4xl font-black">
          <span x-text="g.currentQuestion ? g.currentQuestion.num1 : '?'"></span>
          <span class="text-[#9b5de5]">+</span>
          <span x-text="g.currentQuestion ? g.currentQuestion.num2 : '?'"></span>
          <span class="text-[#9b5de5]">=</span>
        </div>
        <div
          class="min-h-[56px] w-full max-w-[240px] flex items-center justify-center rounded-12 border-2 px-4 py-2 text-3xl font-black tracking-widest transition-colors"
          :class="g.userInput ? 'border-[#00f5d4] text-[#f3f0ff]' : 'border-[#9b5de5]/30 text-[#b5a9df]/40'"
        >
          <span x-text="g.userInput || '?'"></span>
        </div>
      </div>

      <!-- Numpad -->
      <div class="grid grid-cols-3 gap-2 landscape:w-[300px] landscape:shrink-0">
        <template x-for="n in [1,2,3,4,5,6,7,8,9]" :key="n">
          <button type="button" class="key-btn h-14" @click="g.pressKey(n)" x-text="n"></button>
        </template>
        <button type="button" class="key-btn h-14 text-[#fee440]" @click="g.backspace()">⌫</button>
        <button type="button" class="key-btn h-14" @click="g.pressKey(0)">0</button>
        <button
          type="button"
          class="h-14 rounded-14 btn-primary font-black text-lg"
          @click="g.submitAnswer()"
        >決定</button>
      </div>
    </div>

    <!-- ===== Modals ===== -->

    <!-- Stage Clear -->
    <template x-if="g.stageCleared">
      <div class="fixed inset-0 z-50 flex items-center justify-center bg-[#0b0914]/80 backdrop-blur-sm px-4">
        <div class="glass-panel modal-pop w-full max-w-sm p-6 flex flex-col items-center gap-4 text-center">
          <h2 class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#fee440] to-[#f15bb5] glow-text-pink">STAGE CLEAR!</h2>
          <p class="text-sm text-[#b5a9df]">ステージ <span x-text="g.stage"></span> を突破した！</p>
          <div class="w-full flex flex-col gap-1 text-sm">
            <div class="flex justify-between"><span class="text-[#b5a9df]">ステージ得点</span><span class="font-bold text-[#00f5d4]" x-text="'+' + g.lastStageScore.toLocaleString()"></span></div>
            <div class="flex justify-between"><span class="text-[#b5a9df]">撃破ボーナス</span><span class="font-bold text-[#fee440]" x-text="'+' + g.lastDefeatBonus.toLocaleString()"></span></div>
            <div class="mt-1 border-t border-[#9b5de5]/20 pt-1 flex justify-between"><span class="text-[#b5a9df]">合計スコア</span><span class="font-black text-lg text-[#f3f0ff]" x-text="g.score.toLocaleString()"></span></div>
          </div>
          <button type="button" class="w-full btn-primary font-black py-3 text-lg" @click="g.proceedToNextStage()">次のステージへ！</button>
        </div>
      </div>
    </template>

    <!-- Game Completed (All Clear) -->
    <template x-if="g.gameCompleted">
      <div class="fixed inset-0 z-50 flex items-center justify-center bg-[#0b0914]/85 backdrop-blur-sm px-4">
        <div class="glass-panel modal-pop w-full max-w-sm p-6 flex flex-col items-center gap-4 text-center">
          <div class="text-5xl is-pulsing">🏆</div>
          <h2 class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#fee440] via-[#f15bb5] to-[#9b5de5] glow-text-purple">ALL CLEAR!</h2>
          <p class="text-sm text-[#b5a9df]">全12ステージの鬼を退治した！<br />あなたは真の計算マスターだ！</p>
          <div class="text-3xl font-black text-[#00f5d4]" x-text="g.score.toLocaleString() + ' pt'"></div>
          <div class="w-full flex flex-col gap-2">
            <button type="button" class="w-full btn-primary font-black py-3 text-lg" @click="g.goRanking()">ランキングを見る</button>
            <button type="button" class="w-full btn-ghost font-bold py-2.5" @click="g.playAgain()">もう一度あそぶ</button>
          </div>
        </div>
      </div>
    </template>

    <!-- Game Over -->
    <template x-if="g.gameOver">
      <div class="fixed inset-0 z-50 flex items-center justify-center bg-[#0b0914]/85 backdrop-blur-sm px-4">
        <div class="glass-panel modal-pop w-full max-w-sm p-6 flex flex-col items-center gap-4 text-center">
          <div class="text-5xl">💀</div>
          <h2 class="text-3xl font-black text-[#f15bb5] glow-text-pink">GAME OVER</h2>
          <p class="text-sm text-[#b5a9df]">ステージ <span x-text="g.stage"></span> で力尽きた…</p>
          <div class="text-3xl font-black text-[#00f5d4]" x-text="g.score.toLocaleString() + ' pt'"></div>
          <div class="w-full flex flex-col gap-2">
            <button type="button" class="w-full btn-primary font-black py-3 text-lg" @click="g.goRanking()">ランキングを見る</button>
            <button type="button" class="w-full btn-ghost font-bold py-2.5" @click="g.playAgain()">もう一度あそぶ</button>
          </div>
        </div>
      </div>
    </template>

    <!-- Toxic damage overlay -->
    <template x-if="g.takingDamage">
      <div class="toxic-overlay"></div>
    </template>

    <!-- 必殺技 slash cut-in -->
    <template x-if="g.cutIn">
      <div class="cutin">
        <div class="cutin__dim"></div>
        <div class="cutin__slash cutin__slash--accent"></div>
        <div class="cutin__slash cutin__slash--main">
          <div class="cutin__streaks"></div>
        </div>
        <div class="cutin__flash"></div>
        <div class="cutin__char">
          <img src="/images/女教師.png" alt="必殺技" />
        </div>
        <div class="cutin__text">
          <span class="cutin__text-sub">SPECIAL</span>
          <span class="cutin__text-main">必殺技</span>
        </div>
      </div>
    </template>
  </div>
</Layout>

<script>
  import Alpine from 'alpinejs';
  import { gameStore } from '../scripts/game';

  if (!Alpine.store('game')) {
    Alpine.store('game', gameStore());
  }

  // Register exactly once for the lifetime of the tab. View Transitions
  // re-run this script, so guard with a flag on window.
  if (!(window as any).__gameKeyHandler) {
    (window as any).__gameKeyHandler = true;
    window.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.repeat) return;
      const g = Alpine.store('game') as any;
      if (!g || g.locked) return;
      const k = e.key;
      if (k >= '0' && k <= '9') { g.pressKey(k); }
      else if (k === 'Backspace') { e.preventDefault(); g.backspace(); }
      else if (k === 'Enter') { e.preventDefault(); g.submitAnswer(); }
    });
  }
</script>
